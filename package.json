    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "sanitize-filename": "^1.6.4",
    "tabulator-tables": "^6.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
