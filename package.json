{
  "name": "electric",
  "version": "0.1.0",
  "description": "Panel do analizy konfiguratorow aut elektrycznych z PDF.",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "check": "node -e \"require('./src/config').validateConfig({ allowMissingGemini: true }); console.log('config ok')\"",
    "test": "node --test test/equipment.test.js test/recommendation.test.js",
    "test:ux": "playwright test test/ux.test.js",
    "deploy:sync": "node scripts/deploy-runner.js",
    "deploy:status": "node scripts/deploy-runner.js --status"
